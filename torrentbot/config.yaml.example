# Telegram user IDs allowed to use the bot.
# Get yours: message @userinfobot on Telegram.
allowed_chat_ids:
  - 123456789
  - 987654321

paths:
  incomplete: "/Volumes/Mac Backup/Torrents/incomplete"
  complete: "/Volumes/Mac Backup/Torrents/complete"
  tv: "/Volumes/Mac Backup/Shared Videos/TV"
  movies: "/Volumes/Mac Backup/Shared Videos/Movies"

plex:
  url: "http://localhost:32400"
  token: ""           # Settings > General > Troubleshooting > Show > X-Plex-Token
  tv_library_id: "1"  # find via: curl http://localhost:32400/library/sections?X-Plex-Token=TOKEN
  movies_library_id: "2"

sonarr:
  url: "http://localhost:8989"
  api_key: ""   # Sonarr > Settings > General > API Key
  quality_profile_id: 1
  root_folder: "/Volumes/Mac Backup/Shared Videos/TV"

radarr:
  url: "http://localhost:7878"
  api_key: ""   # Radarr > Settings > General > API Key
  quality_profile_id: 1
  root_folder: "/Volumes/Mac Backup/Shared Videos/Movies"

qbittorrent:
  url: "http://localhost:8080"
  username: "admin"
  password: "adminadmin"

quality:
  default_max_size_gb: 4.0
  preferred_quality: "1080p"
  min_seeders: 5
